# Shared group PIN — log activities, edit PRs
# Local default if unset: sally
SALLY_WRITE_PIN=sally

# Administrator password — add / restore / remove people only
# Local default if unset: sally-admin
SALLY_ADMIN_PIN=sally-admin

# Calendar timezone for "today", streaks, eligible days
# Default: Europe/London
SALLY_TIMEZONE=Europe/London

# Production database (required on Vercel)
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=...

# Optional: seed 7 demo people when the DB is empty in production
# (Arya, Bilal, Cal, Jasper, Logan, Martin, Sebastian) — usually leave off
# SALLY_SEED_ON_EMPTY=1
